# pi cloud coding agent — environment configuration
# Copy to `.env` and adjust. docker-compose reads this file automatically.

# --- Server ---
# Host port the web UI / API is exposed on (container always listens on 3000).
PI_PORT=3000

# API key protecting the REST API and WebSocket. Leave empty to DISABLE auth
# (development only — never expose an unauthenticated server publicly).
PI_API_KEY=change-me

# Default model for new sessions, in `provider/modelId` form. Optional.
PI_MODEL=anthropic/claude-sonnet-4-20250514

# --- Database (PostgreSQL) ---
# These configure the bundled postgres service and the server connection.
POSTGRES_DB=pi
POSTGRES_USER=pi
POSTGRES_PASSWORD=pi

# Used when running the server outside docker-compose (points at localhost).
# Inside compose the server uses the postgres service host automatically.
PI_DATABASE_URL=postgres://pi:pi@localhost:5432/pi

# --- Provider credentials (optional) ---
# Either set these here, or configure provider auth in the mounted ./state dir.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
